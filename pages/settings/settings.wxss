.settings-page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f8fafc;
  box-sizing: border-box;
}

.section-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 8rpx 28rpx rgba(15, 23, 42, 0.06);
}

.section-title {
  display: block;
  margin-bottom: 20rpx;
  color: #0f172a;
  font-size: 32rpx;
  font-weight: 700;
}

.hint,
.about-copy {
  display: block;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.55;
}

.profile-row,
.setting-row,
.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #e2e8f0;
}

.profile-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.label { color: #64748b; font-size: 24rpx; }
.value { color: #0f172a; font-size: 30rpx; font-weight: 600; }
.avatar { width: 96rpx; height: 96rpx; border-radius: 50%; }
.small-btn { margin: 0; font-size: 23rpx; }

.row-btn {
  margin-top: 16rpx;
  background: #eff6ff;
  color: #2563eb;
  font-size: 27rpx;
}

.danger { background: #fef2f2; color: #dc2626; }
.language-row { display: flex; gap: 16rpx; margin-top: 20rpx; }

.choice {
  flex: 1;
  border: 2rpx solid #cbd5e1;
  background: #fff;
  font-size: 27rpx;
}

.choice.active { border-color: #3b82f6; background: #eff6ff; color: #2563eb; }
.picker-value { color: #2563eb; }
.info-column { padding-top: 20rpx; }

.backdrop {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  background: rgba(15, 23, 42, 0.55);
}

.avatar-picker {
  width: 100%;
  padding: 32rpx;
  border-radius: 32rpx 32rpx 0 0;
  background: #fff;
  box-sizing: border-box;
}

.avatar-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.avatar-option {
  width: 120rpx;
  height: 120rpx;
  border: 5rpx solid transparent;
  border-radius: 50%;
}

.avatar-option.selected { border-color: #3b82f6; }
