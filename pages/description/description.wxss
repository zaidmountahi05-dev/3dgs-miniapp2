.details-page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f8fafc;
  box-sizing: border-box;
}

.hero {
  width: 100%;
  height: 380rpx;
  border-radius: 28rpx;
  background: #e2e8f0;
}

.card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 8rpx 28rpx rgba(15, 23, 42, 0.06);
}

.heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.heading > view { flex: 1; }
.title { display: block; color: #0f172a; font-size: 38rpx; font-weight: 700; }
.subtitle { display: block; margin-top: 8rpx; color: #64748b; font-size: 26rpx; }
.favorite { margin: 0; background: #eff6ff; color: #2563eb; font-size: 25rpx; }
.favorite.active { background: #fee2e2; color: #dc2626; }
.section-title { display: block; margin-bottom: 16rpx; font-size: 30rpx; font-weight: 700; }
.description { display: block; color: #334155; font-size: 27rpx; line-height: 1.7; }

.meta {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 24rpx;
  color: #64748b;
  font-size: 24rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
  margin-top: 22rpx;
}

.tag-title { width: 100%; font-weight: 600; }
.tag { padding: 8rpx 16rpx; border-radius: 999rpx; background: #f1f5f9; color: #475569; font-size: 23rpx; }
.viewer-btn { margin-top: 28rpx; background: #2563eb; color: #fff; }

.state {
  display: flex;
  min-height: 60vh;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.error { color: #dc2626; }
