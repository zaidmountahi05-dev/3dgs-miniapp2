.container {
  padding: 32rpx;
  min-height: 100vh;
  padding-bottom: 200rpx;
}

.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(59, 130, 246, 0.1);
  margin-bottom: 32rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
  position: relative;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #F1F5F9;
  flex-shrink: 0;
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.user-details {
  flex: 1;
}

.user-name {
  font-size: 48rpx;
  font-weight: 900;
  color: #1E293B;
  letter-spacing: -0.05em;
  display: block;
  margin-bottom: 8rpx;
}

.user-stats {
  font-size: 28rpx;
  color: #64748B;
  display: block;
  margin-bottom: 4rpx;
}

.edit-hint {
  font-size: 24rpx;
  color: #3B82F6;
  padding: 8rpx 16rpx;
  background: #EFF6FF;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.error-text {
  font-size: 28rpx;
  color: #EF4444;
  display: block;
  margin-top: 8rpx;
}

.section {
  margin-bottom: 48rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1E293B;
  margin-bottom: 24rpx;
  display: block;
}

.search-card {
  padding: 20rpx 32rpx;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #F1F5F9;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  color: #94A3B8;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1E293B;
  height: 44rpx;
  min-height: 44rpx;
  line-height: 44rpx;
}

.clear-icon {
  font-size: 24rpx;
  color: #94A3B8;
  padding: 8rpx;
  flex-shrink: 0;
}

.images-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.image-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(59, 130, 246, 0.08);
  transition: all 0.3s ease;
}

.image-card:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 8rpx rgba(59, 130, 246, 0.15);
}

.grid-image {
  width: 100%;
  height: 240rpx;
  display: block;
  background: #E2E8F0;
}

.image-info {
  padding: 20rpx;
  position: relative;
}

.image-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
  display: block;
  margin-bottom: 8rpx;
}

.image-date {
  font-size: 24rpx;
  color: #64748B;
  display: block;
}

.card-actions {
  display: flex;
  gap: 10rpx;
  margin-top: 14rpx;
}

.card-action {
  min-width: 0;
  margin: 0;
  padding: 0 14rpx;
  line-height: 48rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
}

.details-action { background: #eff6ff; color: #2563eb; }
.favorite-action { background: #f8fafc; color: #64748b; }
.favorite-action.active { background: #fef2f2; color: #dc2626; }

.favorite-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: rgba(249, 115, 22, 0.9);
  border-radius: 50%;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.favorite-icon {
  font-size: 24rpx;
  color: #FFFFFF;
}

.empty-state {
  text-align: center;
  padding: 80rpx 32rpx;
  color: #64748B;
  grid-column: 1 / -1;
}

.empty-hint {
  font-size: 24rpx;
  color: #94A3B8;
  display: block;
  margin-top: 16rpx;
}

.nfc-section {
  position: fixed;
  bottom: calc(32rpx + env(safe-area-inset-bottom));
  left: 50%;
  z-index: 20;
  transform: translateX(-50%);
  width: calc(100% - 64rpx);
}

.nfc-btn {
  background: #F97316;
  color: #FFFFFF;
  border-radius: 50rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  width: 100%;
  box-shadow: 0 8rpx 32rpx rgba(249, 115, 22, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-cta {
  background: #F97316;
  color: #FFFFFF;
  border: none;
}

.btn-cta:active {
  background: #EA580C;
  transform: scale(0.98);
}

.btn-secondary {
  background: #3B82F6;
  color: #FFFFFF;
  border: none;
  margin-top: 16rpx;
}

.btn-secondary:active {
  background: #2563EB;
  transform: scale(0.98);
}

.fade-in {
  animation: fadeIn 0.3s ease-in-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.avatar-picker-backdrop {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  animation: fadeIn 0.2s ease-in-out;
}

.avatar-picker {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: 64rpx;
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.picker-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0F172A;
}

.picker-close {
  font-size: 32rpx;
  color: #64748B;
  padding: 8rpx 16rpx;
}

.avatar-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.avatar-option {
  aspect-ratio: 1;
  border-radius: 50%;
  overflow: hidden;
  background: #F1F5F9;
  border: 4rpx solid transparent;
  padding: 6rpx;
}

.avatar-option image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-option.selected {
  border-color: #3B82F6;
  background: #EFF6FF;
}

.avatar-option:active {
  transform: scale(0.95);
}
