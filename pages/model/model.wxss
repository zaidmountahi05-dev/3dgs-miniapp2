.page {
  min-height: 100vh;
  background: #f8fafc;
}

.state-box {
  padding: 100rpx 32rpx;
  text-align: center;
}

.state-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
}

.state-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #64748b;
  line-height: 1.6;
}

.retry-btn {
  margin-top: 32rpx;
  font-size: 28rpx;
}

.viewer-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #f8fafc;
}

.viewer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #e2e8f0;
}

.header-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  overflow: hidden;
}

.scene-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.4;
}

.scene-subtitle {
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.4;
}

.favorite-btn {
  flex-shrink: 0;
  padding: 0 24rpx;
  font-size: 24rpx;
  color: #2563eb;
  background: #ffffff;
  border: 1rpx solid #2563eb;
  border-radius: 12rpx;
}

.favorite-btn.favorited {
  color: #ffffff;
  background: #2563eb;
}

.viewer-shell {
  flex: 1;
  min-height: 900rpx;
  background: #000000;
}

.scene-meta {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 24rpx;
  background: #ffffff;
  border-top: 1rpx solid #e2e8f0;
}

.meta-item {
  font-size: 24rpx;
  line-height: 1.6;
  color: #334155;
  word-break: break-all;
}
