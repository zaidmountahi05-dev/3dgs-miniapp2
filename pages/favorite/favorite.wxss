.container {
  min-height: 100vh;
  padding: 24rpx;
  background: #f8fafc;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
}

.subtitle {
  display: block;
  margin-top: 8rpx;
  color: #64748b;
  font-size: 24rpx;
}

.empty-state {
  padding: 120rpx 24rpx;
  text-align: center;
  color: #64748b;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.empty-subtext {
  display: block;
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 32rpx;
}

.action-btn {
  background: #3B82F6;
  color: #FFFFFF;
  border: none;
  border-radius: 12rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
}

.action-btn:active {
  background: #2563EB;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: #ffffff;
  border-radius: 20rpx;
}

.item-main {
  flex: 1;
  display: flex;
  gap: 20rpx;
}

.thumb {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  background: #e2e8f0;
}

.info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.name {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.sub,
.meta {
  font-size: 24rpx;
  color: #64748b;
}

.delete-btn {
  font-size: 24rpx;
  color: #EF4444;
  background: #FEF2F2;
  border: none;
  border-radius: 12rpx;
  padding: 12rpx 24rpx;
}

.delete-btn:active {
  background: #FEE2E2;
}
