<view class="container">
  <view class="header">
    <view>
      <text class="title">{{i18n.history.title}}</text>
      <text class="subtitle">{{countLabel}}</text>
    </view>
    <button
      wx:if="{{historyModels.length > 0}}"
      class="clear-btn"
      bindtap="clearHistory"
    >
      {{i18n.common.clear}}
    </button>
  </view>

  <view wx:if="{{historyModels.length === 0}}" class="empty-state">
    <view class="empty-icon">◷</view>
    <text class="empty-text">{{i18n.history.empty}}</text>
    <text class="empty-subtext">{{i18n.history.hint}}</text>
    <button class="action-btn" bindtap="goToScan">{{i18n.history.explore}}</button>
  </view>

  <view wx:else class="list">
    <view
      wx:for="{{historyModels}}"
      wx:key="id"
      class="item"
      bindtap="openModel"
      data-model="{{item}}"
    >
      <image class="thumb" src="{{item.thumbnail}}" mode="aspectFill"></image>
      <view class="info">
        <text class="name">{{item.title}}</text>
        <text class="sub">{{item.subtitle}}</text>
        <text class="meta">{{item.lastViewedLabel}}</text>
      </view>
    </view>
  </view>
</view>
