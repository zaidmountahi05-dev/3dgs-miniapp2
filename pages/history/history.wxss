.container {
  min-height: 100vh;
  padding: 24rpx;
  background: #f8fafc;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
}

.subtitle {
  display: block;
  margin-top: 8rpx;
  color: #64748b;
  font-size: 24rpx;
}

.clear-btn {
  font-size: 24rpx;
}

.empty-state {
  text-align: center;
  padding: 120rpx 24rpx;
  color: #64748b;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.empty-subtext {
  display: block;
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 32rpx;
}

.action-btn {
  background: #3B82F6;
  color: #FFFFFF;
  border: none;
  border-radius: 12rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
}

.action-btn:active {
  background: #2563EB;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.item {
  display: flex;
  gap: 20rpx;
  background: #ffffff;
  padding: 20rpx;
  border-radius: 20rpx;
}

.item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(59, 130, 246, 0.1);
}

.thumb {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  background: #e2e8f0;
}

.info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  flex: 1;
}

.name {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.sub,
.meta {
  font-size: 24rpx;
  color: #64748b;
}
